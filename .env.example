# ─────────────────────────────────────────────────────────
# toon-generator — environment variables
# Copy to .env.local and fill in values for local development.
# ─────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Supabase (auth + postgres + storage)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI Providers
REPLICATE_API_TOKEN=
GOOGLE_AI_API_KEY=
ANTHROPIC_API_KEY=

# Self-hosted GPU (future swap target — leave empty until ready)
LOCAL_GPU_ENDPOINT=
LOCAL_GPU_API_KEY=

# Storage (Cloudflare R2, S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=toongen-images
R2_PUBLIC_URL=

# Queue (Upstash Redis recommended)
REDIS_URL=

# Payments
TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=
TOSS_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# AI routing — change these values to swap providers without code changes.
#   allowed values: 'replicate' | 'google-ai' | 'local-gpu' | 'fake'
AI_ROUTING_CHARACTER=google-ai
AI_ROUTING_SCENE=replicate
AI_ROUTING_SKETCH=replicate
